{
  "strategy": {
    "name": "RSI(2) + IBS Combo",
    "version": "1.0",
    "description": "Combines Connors RSI(2) with IBS filter. Fewer trades but higher quality — both oscillator and price action must confirm.",
    "source": "Connors + Pagonidis research combined",
    "timeframe": "1d"
  },
  "watchlist": ["SPY", "QQQ", "IWM", "DIA", "XLF", "XLK", "GLD", "TLT"],
  "entry_rules": {
    "long": [
      {
        "condition": "price > sma_200",
        "weight": 0.34,
        "description": "Above 200-day SMA — uptrend filter"
      },
      {
        "condition": "rsi_2 < 10",
        "weight": 0.33,
        "description": "RSI(2) extreme oversold"
      },
      {
        "condition": "ibs < 0.3",
        "weight": 0.33,
        "description": "IBS < 0.3 — close near the low confirms selling pressure"
      }
    ],
    "short": [
      {
        "condition": "price < sma_200",
        "weight": 0.34,
        "description": "Below 200-day SMA — downtrend filter"
      },
      {
        "condition": "rsi_2 > 90",
        "weight": 0.33,
        "description": "RSI(2) extreme overbought"
      },
      {
        "condition": "ibs > 0.7",
        "weight": 0.33,
        "description": "IBS > 0.7 — close near the high confirms buying exhaustion"
      }
    ],
    "min_score": 0.95,
    "short_min_score": 0.95,
    "note": "All conditions must pass for both sides. Highest quality filter."
  },
  "exit_rules": [
    {
      "condition": "rsi_2 > 80",
      "description": "RSI(2) recovered — mean reversion complete"
    },
    {
      "condition": "ibs > 0.7",
      "description": "IBS > 0.7 — closed near high, momentum fading"
    }
  ],
  "short_exit_rules": [
    {
      "condition": "rsi_2 < 20",
      "description": "RSI(2) crashed — cover short"
    },
    {
      "condition": "ibs < 0.3",
      "description": "IBS < 0.3 — closed near low, downside exhausted"
    }
  ],
  "risk_rules": {
    "max_position_pct": 0.10,
    "max_daily_loss_pct": 0.02,
    "stop_loss_pct": 0.03,
    "take_profit_pct": 0.05,
    "short_stop_loss_pct": 0.03,
    "short_take_profit_pct": 0.05,
    "note": "Trades less frequently but with higher conviction."
  }
}
