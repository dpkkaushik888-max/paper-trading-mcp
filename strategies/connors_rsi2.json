{
  "strategy": {
    "name": "Connors RSI(2)",
    "version": "1.0",
    "description": "Larry Connors' 2-period RSI mean reversion. Buy extreme oversold in uptrend, sell when RSI recovers. 91% win rate historically on SPY.",
    "source": "Short Term Trading Strategies That Work (2008)",
    "timeframe": "1d"
  },
  "watchlist": ["SPY", "QQQ", "IWM", "DIA", "XLF", "XLK", "GLD", "TLT"],
  "entry_rules": {
    "long": [
      {
        "condition": "rsi_2 < 10",
        "weight": 0.50,
        "description": "RSI(2) extreme oversold — core signal"
      },
      {
        "condition": "price > sma_200",
        "weight": 0.50,
        "description": "Above 200-day SMA — uptrend filter"
      }
    ],
    "short": [
      {
        "condition": "rsi_2 > 90",
        "weight": 0.50,
        "description": "RSI(2) extreme overbought — core signal"
      },
      {
        "condition": "price < sma_200",
        "weight": 0.50,
        "description": "Below 200-day SMA — downtrend filter"
      }
    ],
    "min_score": 0.95,
    "short_min_score": 0.95,
    "note": "Both conditions must pass (0.50 + 0.50 = 1.0 > 0.95)"
  },
  "exit_rules": [
    {
      "condition": "rsi_2 > 80",
      "description": "RSI(2) recovered — take profit"
    }
  ],
  "short_exit_rules": [
    {
      "condition": "rsi_2 < 20",
      "description": "RSI(2) crashed — cover short"
    }
  ],
  "risk_rules": {
    "max_position_pct": 0.10,
    "max_daily_loss_pct": 0.02,
    "stop_loss_pct": 0.03,
    "take_profit_pct": 0.05,
    "short_stop_loss_pct": 0.03,
    "short_take_profit_pct": 0.05,
    "note": "Connors does not use stops, but 3% safety stop added per Bellelli."
  }
}
